-- Configuração das Senhas
local senhas_validas = {
    "AHWDAFMWA", "WDAGNWASDN", "WDCNASNGOW", "WADSBMZNXCU", "WDANBNZAPZ",
    "CWDASBALSD", "LASKVJASOWJ", "WDASIVIASJNV", "PASUVASIWSDW", "SDZOWUWNFW"
}

-- Função para verificar se a senha está na lista
local function verificar_senha(entrada)
    for _, senha in pairs(senhas_validas) do
        if entrada == senha then
            return true
        end
    end
    return false
end

