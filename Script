    while true do
        if RewardRemote then
            if Settings.AutoToken then 
                pcall(function() RewardRemote:InvokeServer(1) end) 
                task.wait(math.random(3, 4)) 
            end
            if Settings.AutoAbility then 
                pcall(function() RewardRemote:InvokeServer(4) end) 
